; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="PNGTube-Remix"
config/version="1.4.6"
run/main_scene="uid://ckgt30cxu04dj"
run/print_header=false
config/quit_on_go_back=false
config/features=PackedStringArray("4.6")
run/max_fps=60
run/frame_delay_msec=4
boot_splash/bg_color=Color(0.1118, 0.135361, 0.218212, 1)
boot_splash/stretch_mode=0
boot_splash/use_filter=false
boot_splash/image="res://SplashImage.png"
config/icon="res://PicklesSurprised.png"
config/macos_native_icon="res://PicklesSurprisedre.icns"
config/windows_native_icon="res://PicklesSurprised.ico"

[audio]

buses/default_bus_layout="uid://b2xlc2esq3cvw"
driver/output_latency=100

[autoload]

VersionConverter="*res://Scripts/AutoLoads/VersionConversion/VersionConverter.tscn"
Global="*res://Main/Scripts/Global.gd"
LoadMisc="*uid://bqxqiptwa1wsc"
SaveAndLoad="*res://Main/Scripts/SaveAndLoad.gd"
Settings="*res://Scripts/AutoLoads/Settings.gd"
GlobalAudioStreamPlayer="*res://Scripts/AutoLoads/audio_stream_player.tscn"
LipSyncGlobals="*res://UI/Lipsync stuff/godot-lip-sync/lip_sync_globals.gd"
GlobalMicAudio="*res://Main/Scripts/GlobalMicAudio.gd"
WebsocketHandler="*res://Main/Scripts/websocket_handler.gd"
GlobInput="*res://Scripts/AutoLoads/global_input.tscn"
CommandLine="*uid://bb316uj87yar8"
Tracker="*res://Scripts/Trackings/TrackingBackend.gd"
LanguageManager="*uid://htrtywrh8c4v"

[debug]

settings/crash_handler/message="Please include this when reporting the bug on:https://github.com/MudkipWorld/PNGTuber-Remix/issues"
settings/crash_handler/message.editor="Please include this when reporting the bug on:https://github.com/MudkipWorld/PNGTuber-Remix/issues"
gdscript/warnings/unused_signal=0
gdscript/warnings/integer_division=0
gdscript/warnings/get_node_default_without_onready=0

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/transparent=true
window/energy_saving/keep_screen_on=false
window/stretch/aspect="ignore"
window/per_pixel_transparency/allowed=true
window/vsync/vsync_mode=2
window/enable_file_logging.pc=true
window/enable_file_logging=false

[editor_plugins]

enabled=PackedStringArray("res://addons/aimg_io/plugin.cfg", "res://addons/wiggly_appendage_2d/plugin.cfg")

[global_group]

Layers=""
InputsUIs=""
StateRemapButton=""
Dockables=""
Meshes=""
Mehses=""
DeformButtons=""

[gui]

theme/custom_font="uid://2jnndjm4c7yc"

